#!/usr/bin/env bash
set -euo pipefail

echo "== Harness verification for {{project_name}} =="
echo "Detected stack: {{detected_stack}}"

PYTHON_BIN="${PYTHON:-}"
if [ -z "$PYTHON_BIN" ]; then
  if command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
  else
    PYTHON_BIN="python"
  fi
fi

{{commands_shell}}

if [ -f scripts/check_pins.py ]; then
  echo "== python scripts/check_pins.py --root . =="
  "$PYTHON_BIN" scripts/check_pins.py --root .
fi

if command -v repo-harness >/dev/null 2>&1; then
  echo "== repo-harness audit --target . --min-score 85 =="
  repo-harness audit --target . --min-score 85
elif "$PYTHON_BIN" -m repo_harness_creator --version >/dev/null 2>&1; then
  echo "== python -m repo_harness_creator audit --target . --min-score 85 =="
  "$PYTHON_BIN" -m repo_harness_creator audit --target . --min-score 85
else
  echo "== repo-harness audit skipped: repo-harness is not installed =="
fi

echo "== Harness verification complete =="
